{
  "name": "envia-mcp",
  "version": "0.2.0",
  "description": "MCP server and client library for Envia.com shipping API — quote, label, track, and cancel shipments across 170+ carriers in 18 countries",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./client": "./dist/client.js",
    "./types": "./dist/types.js"
  },
  "bin": {
    "envia-mcp": "./dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "envia",
    "shipping",
    "client",
    "sdk",
    "typescript",
    "mexico",
    "latin-america",
    "logistics",
    "carriers",
    "tracking"
  ],
  "author": "amak07",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amak07/envia-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.1"
  }
}
