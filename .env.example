# ─── Envia API ───────────────────────────────────────────────────────────────
# Same key for Shipping + Queries APIs. Sandbox and production use SEPARATE keys.
ENVIA_API_KEY=your-sandbox-api-key-here

# Default: Sandbox (safe for testing — no real charges)
# No URL overrides needed — sandbox is the default

# Production (uncomment to use real API — labels cost real money):
# ENVIA_SHIPPING_URL=https://api.envia.com
# ENVIA_QUERIES_URL=https://queries.envia.com
# ENVIA_GEOCODES_URL=https://geocodes.envia.com

# ─── npm Publishing ─────────────────────────────────────────────────────────
# Granular access token with read/write + bypass 2FA
# Generate at: https://www.npmjs.com/settings/~/tokens → Granular Access Token
# Usage: echo "//registry.npmjs.org/:_authToken=$NPM_TOKEN" > .npmrc && npm.cmd publish --access public && rm .npmrc
NPM_TOKEN=your-npm-token-here
