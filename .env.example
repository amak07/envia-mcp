# Envia API Key (same key for Shipping + Queries APIs)
# Note: sandbox and production use SEPARATE API keys
ENVIA_API_KEY=your-sandbox-api-key-here

# Default: Sandbox (safe for testing — no real charges)
# No URL overrides needed — sandbox is the default

# Production (uncomment to use real API — labels cost real money):
# ENVIA_SHIPPING_URL=https://api.envia.com
# ENVIA_QUERIES_URL=https://queries.envia.com
# ENVIA_GEOCODES_URL=https://geocodes.envia.com
